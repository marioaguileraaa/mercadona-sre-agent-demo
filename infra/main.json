      "properties": {
        "description": "Synthetic retail backend working set exceeded 600 MiB in the controlled cart-memory demo.",
        "severity": 2,
        "enabled": true,
        "scopes": [
          "[resourceId('Microsoft.App/containerApps', variables('backendName'))]"
        ],
        "evaluationFrequency": "PT1M",
        "windowSize": "PT5M",
        "targetResourceType": "Microsoft.App/containerApps",
        "targetResourceRegion": "[parameters('location')]",
        "criteria": {
          "odata.type": "Microsoft.Azure.Monitor.SingleResourceMultipleMetricCriteria",
          "allOf": [
            {
              "name": "CartMemoryWorkingSet",
              "metricNamespace": "Microsoft.App/containerApps",
              "metricName": "WorkingSetBytes",
              "operator": "GreaterThan",
              "threshold": 629145600,
              "timeAggregation": "Maximum",
              "criterionType": "StaticThresholdCriterion"
            }
          ]
        },
        "autoMitigate": true,
